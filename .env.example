# =====================================================================
# Brevo (formerly Sendinblue) — free plan: 300 emails/day
# =====================================================================
# 1. Sign up: https://www.brevo.com/
# 2. Get an API key:
#    Brevo dashboard -> SMTP & API -> API Keys -> "Generate a new API key"
#    Paste it as BREVO_API_KEY below.
# 3. Add a verified sender:
#    Brevo dashboard -> Senders, Domains & Dedicated IPs -> Senders
#    -> "Add a sender". Use one of your Gmail addresses (e.g.
#    pranshu.bisht.java@gmail.com). Brevo will email a confirmation
#    link to that address — click it. Then put that address in
#    BREVO_SENDER_EMAIL below.
# 4. Recipients DO NOT need to be verified. The two Gmails will receive
#    quote requests via CONTACT_RECIPIENT_EMAILS below.
# ---------------------------------------------------------------------

BREVO_API_KEY=your-brevo-api-key-here
BREVO_SENDER_EMAIL=pranshu.bisht.java@gmail.com
BREVO_SENDER_NAME=Designvate Website

# =====================================================================
# Where contact-form submissions are delivered.
# Comma-separated list. Both Gmails receive every submission.
# =====================================================================
CONTACT_RECIPIENT_EMAILS=pranshu.bisht.java@gmail.com,pranshu.java@gmail.com
